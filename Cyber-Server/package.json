{
  "name": "cyber-server",
  "type": "module",
  "version": "1.0.0",
  "description": "Cyber backend — Fastify + Prisma + MySQL + JWT",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "lsof -ti:5588 | xargs kill -9 2>/dev/null; tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "lint": "eslint src --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "10.0.2",
    "@fastify/jwt": "9.1.0",
    "@prisma/client": "6.5.0",
    "bcryptjs": "3.0.2",
    "element-plus-china-area": "1.0.4",
    "fastify": "5.3.2",
    "fastify-plugin": "5.1.0",
    "pino-pretty": "13.1.3",
    "svg-captcha": "1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "25.3.5",
    "eslint": "10.0.3",
    "prisma": "6.5.0",
    "tsx": "4.19.3",
    "typescript": "5.9.3"
  }
}
