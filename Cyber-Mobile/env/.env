VITE_APP_TITLE = 'Cyber Mobile'
VITE_APP_PORT = 5566

VITE_UNI_APPID = '__UNI__D1E5001'
VITE_WX_APPID = 'wxa2abb91f64032a2b'

# h5部署网站的base，配置到 manifest.config.ts 里的 h5.router.base
# https://uniapp.dcloud.net.cn/collocation/manifest.html#h5-router
# 比如你要部署到 https://example.com/app/ ，则配置为 /app/
VITE_APP_PUBLIC_BASE=/

# 后台请求地址（开发时由 .env.development 覆盖，生产时由 .env.production 覆盖）
VITE_SERVER_BASEURL = 'http://localhost:5588/api/v1'

# h5是否需要配置代理
VITE_APP_PROXY_ENABLE = false
# 代理前缀（仅 H5 且 VITE_APP_PROXY_ENABLE=true 时生效）
VITE_APP_PROXY_PREFIX = '/fg-api'

# 第二个请求地址 (目前alova中可以使用)
VITE_SERVER_BASEURL_SECONDARY = ''

# 认证模式，'single' | 'double' ==> 单token | 双token
VITE_AUTH_MODE = 'single'

# 原生插件资源复制开关，控制是否启用 copy-native-resources 插件
VITE_COPY_NATIVE_RES_ENABLE = false
