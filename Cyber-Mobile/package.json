{
  "name": "cyber-mobile",
  "type": "module",
  "version": "1.0.0",
  "description": "Cyber 移动端 — uni-app + Vue 3 + TypeScript，支持 H5、微信小程序、App",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "predev": "node -e \"const fs=require('fs'),p='src/manifest.json';if(!fs.existsSync(p)){fs.mkdirSync('src',{recursive:true});fs.writeFileSync(p,JSON.stringify({name:'',appid:'',versionName:'1.0.0',versionCode:'100',transformPx:false,'app-plus':{usingComponents:true}},null,2))}\"",
    "dev": "uni -p mp-weixin",
    "dev:h5": "uni",
    "dev:h5:test": "uni --mode test",
    "dev:h5:prod": "uni --mode production",
    "dev:mp": "uni -p mp-weixin",
    "dev:mp:test": "uni -p mp-weixin --mode test",
    "dev:mp:prod": "uni -p mp-weixin --mode production",
    "dev:app": "uni -p app",
    "dev:app-android": "uni -p app-android",
    "dev:app-ios": "uni -p app-ios",
    "build:h5": "uni build",
    "build:h5:prod": "uni build --mode production",
    "build:mp": "uni build -p mp-weixin",
    "build:mp:prod": "uni build -p mp-weixin --mode production",
    "build:app": "uni build -p app",
    "build:app-android": "uni build -p app-android",
    "build:app-ios": "uni build -p app-ios",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@alova/adapter-uniapp": "2.0.16",
    "@alova/shared": "1.3.2",
    "@dcloudio/uni-app": "3.0.0-4070620250821001",
    "@dcloudio/uni-app-harmony": "3.0.0-4070620250821001",
    "@dcloudio/uni-app-plus": "3.0.0-4070620250821001",
    "@dcloudio/uni-components": "3.0.0-4070620250821001",
    "@dcloudio/uni-h5": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-harmony": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-jd": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-lark": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-qq": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4070620250821001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4070620250821001",
    "abortcontroller-polyfill": "1.7.8",
    "alova": "3.5.1",
    "dayjs": "1.11.19",
    "element-plus-china-area": "1.0.4",
    "pinia": "2.3.1",
    "pinia-plugin-persistedstate": "3.2.1",
    "vue": "3.5.29",
    "vue-i18n": "9.1.9",
    "vue-router": "4.5.1",
