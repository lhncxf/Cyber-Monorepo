    "@vue/runtime-core": "3.5.29",
    "@vue/tsconfig": "0.1.3",
    "autoprefixer": "10.4.27",
    "cross-env": "10.1.0",
    "eslint": "10.0.3",
    "eslint-plugin-format": "2.0.1",
    "fs-extra": "11.3.4",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "miniprogram-api-typings": "4.1.3",
    "miniprogram-ci": "2.1.26",
    "openapi-ts-request": "1.12.6",
    "postcss": "8.5.8",
    "postcss-html": "1.8.1",
    "postcss-scss": "4.0.9",
    "rollup-plugin-visualizer": "6.0.11",
    "sass": "1.77.8",
    "std-env": "3.10.0",
    "typescript": "5.9.3",
    "unocss": "66.0.0",
    "unplugin-auto-import": "21.0.0",
    "vite": "5.2.8",
    "vite-plugin-restart": "1.0.0",
    "vite-plugin-vue-devtools": "8.0.7",
    "vue-tsc": "3.2.5"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
